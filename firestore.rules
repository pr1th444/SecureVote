rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: elections
    // Document ID: electionId
    // Fields:
    //   - title: string (required)
    //   - description: string (optional)
    //   - startTime: timestamp (required)
    //   - endTime: timestamp (required)
    //   - isActive: bool (required)
    //
    // Collection: elections/{electionId}/candidates
    // Document ID: candidateId
    // Fields:
    //   - name: string (required)
    //   - bio: string (optional)
    //   - electionId: string (required)
    //   - voteCount: number (required)
    //
    // Collection: voters
    // Document ID: userId_electionId
    // Fields:
    //   - userId: string (required)
    //   - electionId: string (required)
    //   - hasVoted: bool (required)
    //
    // Collection: votes
    // Document ID: auto-generated
    // Fields:
    //   - electionId: string (required)
    //   - candidateId: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "pritha.d06@gmail.com" && request.auth.token.email_verified == true);
    }

    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    match /elections/{electionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      
      match /candidates/{candidateId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
        allow update: if isAuthenticated() && 
                        request.resource.data.voteCount == resource.data.voteCount + 1;
      }
    }

    match /voters/{voterId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && voterId.startsWith(request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /votes/{voteId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }
  }
}
